# ─────────────────────────────────────────────────────────────────────────────
# Atlas — Environment Variables Template
# Copy this file to .env and fill in values. All Tier-2 vars are optional;
# the app runs fully in keyless mode with an empty .env.
# ─────────────────────────────────────────────────────────────────────────────

# Published host port (container always listens on 3000 internally)
ATLAS_PORT=3000

# ── Map tiles ────────────────────────────────────────────────────────────────
# Override the basemap tile style URL (default: OpenFreeMap Liberty style)
# TILE_URL=https://tiles.openfreemap.org/styles/liberty

# ── Geocoding ────────────────────────────────────────────────────────────────
# Override Nominatim instance (default: https://nominatim.openstreetmap.org)
# NOMINATIM_URL=https://nominatim.openstreetmap.org

# ── On-disk cache ────────────────────────────────────────────────────────────
# Directory for optional persistent JSON cache (default: ./.cache)
# CACHE_DIR=./.cache

# ─────────────────────────────────────────────────────────────────────────────
# TIER-2: Optional API keys — add these to get live prices, real deals,
# and accurate peak/off-peak data. Without them the app uses estimates.
# ─────────────────────────────────────────────────────────────────────────────

# Amadeus Self-Service API (https://developers.amadeus.com — free test tier)
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=

# Travelpayouts / Aviasales Data API (https://www.travelpayouts.com/developers/api)
# TRAVELPAYOUTS_TOKEN=
